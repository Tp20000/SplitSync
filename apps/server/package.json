{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "test": "dotenv -e .env.test -- jest --verbose --testPathPattern=tests/unit",
    "test:unit": "dotenv -e .env.test -- jest --verbose --testPathPattern=tests/unit",
    "test:integration": "dotenv -e .env.test -- jest --verbose --testPathPattern=tests/integration --runInBand",
    "test:all": "dotenv -e .env.test -- jest --verbose --runInBand",
    "test:coverage": "dotenv -e .env.test -- jest --coverage --runInBand"
  },
  "dependencies": {
