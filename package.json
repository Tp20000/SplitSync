{
  "name": "splitsync",
  "private": true,
  "workspaces": ["apps/web", "apps/server"],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspace=server",
    "test:unit": "npm run test:unit --workspace=server",
    "test:integration": "npm run test:integration --workspace=server",
    "test:coverage": "npm run test:coverage --workspace=server",
    "docker:build": "docker-compose -f docker-compose.prod.yml build",
    "docker:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose -f docker-compose.prod.yml down"
  }
}